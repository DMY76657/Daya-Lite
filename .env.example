# Neon PostgreSQL — copy from Neon dashboard > Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-byte-random-hex"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed script — pick any password for the demo accounts.
# Required by `npm run db:seed`. Kept out of source on purpose so the
# live-site demo password isn't visible in the GitHub repo.
SEED_PASSWORD="pick-any-strong-password"
# Optional overrides (defaults are admin@daya.bg / user@daya.bg)
# SEED_ADMIN_EMAIL="admin@daya.bg"
# SEED_USER_EMAIL="user@daya.bg"
