{
  "expo": {
    "name": "Daya Lite",
    "slug": "daya-lite",
    "version": "1.0.0",
    "scheme": "daya-lite",
    "orientation": "portrait",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mydaya.lite",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.mydaya.lite",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e3e688e0-d052-4d2d-8afb-4ae6321db568"
      }
    }
  }
}
